# Copy to .env and fill in your NeonDB connection string.
# Never commit .env to git.

# Get this from your Neon project dashboard → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/rxregistry?sslmode=require

PORT=3001
NODE_ENV=development

# Set to your frontend URL in production, e.g. https://rxregistry.onrender.com
CORS_ORIGIN=http://localhost:5173
